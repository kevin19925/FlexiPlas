# MongoDB Atlas — Cadena de conexión completa
MONGODB_URI=mongodb+srv://usuario:password@cluster.mongodb.net/

# Nombre de la base de datos en MongoDB Atlas
MONGODB_DB_NAME=sis_archivos

# Azure Blob Storage — cadena de conexión del Storage Account
AZURE_STORAGE_CONNECTION_STRING=DefaultEndpointsProtocol=https;AccountName=...;AccountKey=...;EndpointSuffix=core.windows.net

# Nombre del contenedor en Azure Blob Storage (debe existir y ser privado)
AZURE_STORAGE_CONTAINER=archivos

# Secreto para firmar JWT — usar un string aleatorio de mínimo 32 caracteres
JWT_SECRET=cambiar-esto-por-un-secreto-largo-y-seguro-32chars
